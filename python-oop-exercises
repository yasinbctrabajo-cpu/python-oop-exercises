    "# Defino la clase Alumno con los atributos nombre y nota\n",
    "class Alumno:\n",
    "    def __init__(self, nombre, nota):\n",
    "        # Guardo el nombre y la nota del alumno\n",
    "        self.nombre = nombre\n",
    "        self.nota = nota\n",
    "        \n",
    "        # Informo que el alumno se ha creado correctamente\n",
    "        print(f\"Alumno {self.nombre} creado con éxito\")\n",
    "\n",
    "    # Sobrescribo el método __str__ para mostrar la información del alumno\n",
    "    def __str__(self):\n",
