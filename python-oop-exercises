    "# Defino la clase Alumno usando atributos “privados” con un guion bajo según el enunciado\n",
    "class Alumno:\n",
    "    def __init__(self, nombre, nota):\n",
    "        # Guardo los datos del alumno con guion bajo para indicar que no se deben tocar directamente\n",
    "        self._nombre = nombre\n",
    "        self._nota = nota\n",
    "        print(f\"Alumno {self._nombre} creado con éxito\")\n",
    "\n",
