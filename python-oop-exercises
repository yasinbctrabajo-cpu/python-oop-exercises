    "        else:\n",
    "            return \"Suspenso\"\n",
    "\n",
    "    # Devuelve el nombre usando un getter\n",
    "    def get_nombre(self):\n",
    "        return self._nombre\n",
    "\n",
    "    # Permite cambiar el nombre usando un setter\n",
    "    def set_nombre(self, nuevo_nombre):\n",
