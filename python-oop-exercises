    "# Esta clase representa al propietario de una vivienda\n",
    "class Propietario:\n",
    "    def __init__(self, nombre, dni, telefono):\n",
    "        # Guardo los datos básicos de la persona\n",
    "        self.nombre = nombre\n",
    "        self.dni = dni\n",
    "        self.telefono = telefono\n",
    "\n",
    "    def __str__(self):\n",
    "        # Devuelvo su información en formato texto\n",
    "        return f\"Propietario: {self.nombre} | DNI: {self.dni} | Teléfono: {self.telefono}\"\n",
    "\n",
    "\n",
    "# Esta es la clase base de todas las viviendas\n",
    "class Vivienda:\n",
    "    def __init__(self, direccion, metros_cuadrados, precio, propietario):\n",
    "        # Aquí guardo los datos comunes a cualquier vivienda\n",
    "        self.direccion = direccion\n",
    "        self.metros_cuadrados = metros_cuadrados\n",
    "        self.precio = precio\n",
    "        self.propietario = propietario  # Aquí estoy guardando un objeto Propietario\n",
    "\n",
    "    def __str__(self):\n",
    "        # Devuelvo la información general de la vivienda\n",
    "        return (f\"Ubicación: {self.direccion} | \"\n",
    "                f\"Tamaño: {self.metros_cuadrados} m² | \"\n",
    "                f\"Precio: {self.precio}€\")\n",
    "\n",
    "\n",
    "# Casa hereda de Vivienda y añade si tiene jardín o no\n",
    "class Casa(Vivienda):\n",
    "    def __init__(self, direccion, metros_cuadrados, precio, propietario, jardin):\n",
    "        # Uso super para aprovechar el constructor de la clase padre\n",
    "        super().__init__(direccion, metros_cuadrados, precio, propietario)\n",
    "        self.jardin = jardin\n",
    "\n",
    "    def tiene_jardin(self):\n",
    "        # Este método solo existe en Casa\n",
    "        if self.jardin:\n",
    "            return \"Esta casa tiene jardín\"\n",
    "        else:\n",
    "            return \"Esta casa no tiene jardín\"\n",
    "\n",
    "    def __str__(self):\n",
    "        # Amplío la información general añadiendo los datos específicos\n",
    "        jardin_texto = \"Sí\" if self.jardin else \"No\"\n",
    "        return (super().__str__() + \"\\n\" +\n",
    "                f\"{self.propietario} | Tipo: Casa | Jardín: {jardin_texto}\")\n",
