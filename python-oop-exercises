    "\n",
    "# Muestro los objetos alumno usando __str__\n",
    "print(\"\\nMostrando alumnos:\")\n",
    "for alumno in alumnos:\n",
    "    print(alumno)\n",
    "\n",
    "# Pruebo el método calificacion\n",
    "print(\"\\nProbando método calificacion:\")\n",
    "for alumno in alumnos:\n",
    "    alumno.calificacion()\n"
